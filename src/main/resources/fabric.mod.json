{
  "schemaVersion": 1,
  "id": "build-bugs",
  "version": "${version}",
  "name": "Build Bugs",
  "description": "Simple Utility mod to speed up (build-) bug reports on MCC Island!",
  "authors": [
    "derNiklaas"
  ],
  "contact": {
    "homepage": "https://github.com/derNiklaas/build-bugs",
    "email": "info@derniklaas.de",
    "sources": "https://github.com/derniklaas/build-bugs",
    "issues": "https://github.com/derNiklaas/build-bugs/issues"
  },
  "license": "MIT",
  "icon": "assets/buildbugs/icon.png",
  "environment": "client",
  "entrypoints": {
    "noxesium": [
      {
        "adapter": "kotlin",
        "value": "de.derniklaas.buildbugs.BuildBugsClientEntrypoint"
      }
    ]
  },
  "mixins": [
    "buildbugs.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric-api": "*",
    "minecraft": ">=1.21.8",
    "java": ">=17",
    "fabric-language-kotlin": "*",
    "noxesium": "*"
  },
  "custom": {
    "modmenu": {
      "links": {
        "modmenu.modrinth": "https://modrinth.com/mod/build-bugs/",
        "modmenu.github_releases": "https://github.com/derNiklaas/build-bugs/releases"
      },
      "update_checker": true
    }
  }
}
